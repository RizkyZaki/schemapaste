{
  "name": "schemapaste",
  "version": "0.1.0",
  "private": true,
  "description": "SchemaPaste VS Code extension monorepo",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @schemapaste/webview dev",
    "watch:extension": "pnpm --filter @schemapaste/extension watch",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @schemapaste/core test",
    "package:vsix": "pnpm build && pnpm --filter schemapaste package"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}